<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dropdown Dinamis - Rumus Segitiga</title>
    <style>
        /* --- 1. KODE CSS ASLI RANCANGAN ANDA (GAMBAR 1, 5, 6) --- */
        body {
            font-family: Arial, sans-serif;
            padding: 30px;
            background-color: #f5f5f5;
        }

        /* Kotak Utama Dropdown */
        details {
            width: 300px;
            background-color: #ffffff;
            border: 2px solid #333333;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
        }

        /* Tampilan Header Dropdown */
        summary {
            padding: 15px;
            font-weight: bold;
            background-color: #eaeaea;
            list-style: none;
            display: flex;
            justify-content: space-between;
        }

        /* Desain Baris Menu */
        .baris-menu {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            border-top: 1px solid #cccccc;
            cursor: pointer;
            transition: background 0.2s;
        }

        .baris-menu:hover {
            background-color: #f9f9f9;
        }

        /* Sub-Menu Menjorok ke Kanan */
        .sub-menu {
            padding-left: 45px;
            background-color: #fafafa;
        }

        /* SEMBUNYIKAN SEMUA TOMBOL RADIO BAWAAN BROWSER */
        .baris-menu input[type="radio"] {
            display: none;
        }

        /* KUNCI CSS: Buat bulatan radio tiruan */
        .baris-menu::after {
            content: '';
            width: 12px;
            height: 12px;
            border: 2px solid #666666;
            border-radius: 50%;
            display: inline-block;
            visibility: hidden; /* Sembunyikan bulatan di awal */
        }

        /* Tampilkan lingkaran & beri warna hitam saat class terpilih aktif */
        .baris-menu.terpilih::after {
            visibility: visible;
            background-color: #333333;
            border-color: #333333;
        }

        /* --- 2. STYLE TAMBAHAN KHUSUS UNTUK FORM INPUT ANGKA --- */
        .box-hitung {
            width: 276px;
            background-color: #ffffff;
            border: 2px solid #333333;
            border-radius: 8px;
            margin-top: 15px;
            padding: 10px;
        }
        .input-grup {
            margin-bottom: 10px;
        }
        .input-grup label {
            font-weight: bold;
            font-size: 14px;
        }
        .input-grup input {
            width: 100%;
            padding: 6px;
            box-sizing: border-box;
            border: 1px solid #ccc;
            border-radius: 4px;
            margin-top: 4px;
        }
        .btn-hitung {
            width: 100%;
            padding: 8px;
            background-color: #333333;
            color: #ffffff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }
        .btn-hitung:hover {
            background-color: #555555;
        }
    </style>
</head>
<body>

    <!-- --- 3. STRUKTUR HTML DROPDOWN YANG SUDAH DIPERBAIKI TAG-NYA --- -->
    <details>
        <!-- Judul Dropdown Utama -->
        <summary>
            <span>-- rumus segitiga --</span>
            <span>▼</span>
        </summary>
        
        <!-- Wadah isi menu list -->
        <div style="padding: 5px 0;">
            <!-- Anak menu untuk Segitiga Utama -->
            <ul class="anak-segitiga" id="subMenuSegitiga" style="list-style: none; margin: 0; padding: 0;">
                <li onclick="pilihanAnakSegitiga('Luas', this)" class="baris-menu terpilih">
                    <span>Luas</span>
                    <input type="radio" name="sub_pilihan" value="Luas" checked>
                </li>
                <li onclick="pilihanAnakSegitiga('keliling', this)" class="baris-menu">
                    <span>Keliling</span>
                    <input type="radio" name="sub_pilihan" value="keliling">
                </li>
                <li onclick="pilihanAnakSegitiga('sisi', this)" class="baris-menu">
                    <span>Sisi</span>
                    <input type="radio" name="sub_pilihan" value="sisi">
                </li>
                <li onclick="pilihanAnakSegitiga('sudut', this)" class="baris-menu">
                    <span>Sudut</span>
                    <input type="radio" name="sub_pilihan" value="sudut">
                </li>
            </ul>

            <!-- Anak menu khusus untuk Sudut (Trigonometri) -->
            <ul class="anak-sudut" id="subMenuSudut" style="list-style: none; margin: 0; padding: 0;">
                <li onclick="pilihanAnakSegitiga('sin', this)" class="baris-menu sub-menu">
                    <span>Sin</span>
                    <input type="radio" name="sub_pilihan" value="sin">
                </li>
                <li onclick="pilihanAnakSegitiga('cos', this)" class="baris-menu sub-menu">
                    <span>Cos</span>
                    <input type="radio" name="sub_pilihan" value="cos">
                </li>
                <li onclick="pilihanAnakSegitiga('tan', this)" class="baris-menu sub-menu">
                    <span>Tan</span>
                    <input type="radio" name="sub_pilihan" value="tan">
                </li>
            </ul>
        </div>
    </details>

    <!-- --- 4. KOTAK FORM INPUT ANGKA KALKULATOR --- -->
    <div class="box-hitung">
        <div class="input-grup" id="grup_a">
            <label id="txt_a">Alas (a):</label>
            <input type="number" id="val_a" placeholder="Masukkan nilai">
        </div>
        <div class="input-grup" id="grup_b">
            <label id="txt_b">Tinggi (t):</label>
            <input type="number" id="val_b" placeholder="Masukkan nilai">
        </div>
        <div class="input-grup" id="grup_c" style="display: none;">
            <label id="txt_c">Sisi C (c):</label>
            <input type="number" id="val_c" placeholder="Masukkan nilai">
        </div>
        
        <button class="btn-hitung" onclick="hitungKalkulatorSegitiga()">Hitung</button>
        <p id="output_hasil" style="font-weight: bold; margin-top: 12px; text-align: center;">Hasil: -</p>
    </div>

<!-- --- 5. JAVASCRIPT UNTUK MENGAKTIFKAN SAKELAR BULATAN DAN RUMUS --- -->
<script>
let rumusAktif = 'Luas'; // Menyimpan rumus yang sedang aktif (Bawaan awal: Luas)

function pilihanAnakSegitiga(jenisRumus, elemenAktif) {
    rumusAktif = jenisRumus;

    // 1. Hapus kelas 'terpilih' dari semua elemen <li> agar lingkaran hitam padam
    let semuaLi = document.querySelectorAll('li.baris-menu');
    semuaLi.forEach(li => {
        li.classList.remove('terpilih');
    });

    // 2. Tambahkan kelas 'terpilih' hanya pada elemen <li> yang Anda klik di HP
    if (elemenAktif) {
        elemenAktif.classList.add('terpilih');
    }

    // 3. Cari tag <input type="radio"> di dalam <li> tersebut dan aktifkan centangnya
    const radioAsli = elemenAktif.querySelector('input[type="radio"]');
    if (radioAsli) {
        radioAsli.checked = true;
    }

    // 4. ATUR OTOMATIS TAMPILAN FORM ANGKA SESUAI RUMUS YANG DIKLIK
    let grupB = document.getElementById("grup_b");
    let grupC = document.getElementById("grup_c");
    let txtA = document.getElementById("txt_a");
    let txtB = document.getElementById("txt_b");
    let txtC = document.getElementById("txt_c");

    // Setelan dasar awal (kolom A dan B muncul, C sembunyi)
    grupB.style.display = "block";
    grupC.style.display = "none";

    if (jenisRumus === 'Luas') {
        txtA.innerText = "Alas (a):";
        txtB.innerText = "Tinggi (t):";
    } else if (jenisRumus === 'keliling') {
        txtA.innerText = "Panjang Sisi A:";
        txtB.innerText = "Panjang Sisi B:";
        grupC.style.display = "block"; // Munculkan input sisi C
        txtC.innerText = "Panjang Sisi C:";
    } else if (jenisRumus === 'sisi') {
        txtA.innerText = "Sisi Alas Siku (a):";
        txtB.innerText = "Sisi Tinggi Siku (b):";
    } else if (jenisRumus === 'sudut' || jenisRumus === 'sin' || jenisRumus === 'cos' || jenisRumus === 'tan') {
        txtA.innerText = "Nilai Angka / Derajat:";
        grupB.style.display = "none"; // Rumus sudut/trigonometri hanya butuh 1 kolom input
    }
}

// FUNGSI UTAMA UNTUK MENGEKSEKUSI HITUNGAN
function hitungKalkulatorSegitiga() {
    let a = parseFloat(document.getElementById("val_a").value) || 0;
    let b = parseFloat(document.getElementById("val_b").value) || 0;
    let c = parseFloat(document.getElementById("val_c").value) || 0;
    let hasil = 0;

    if (rumusAktif === 'Luas') {
        hasil = 0.5 * a * b;
        document.getElementById("output_hasil").innerText = "Hasil Luas: " + hasil;
    } else if (rumusAktif === 'keliling') {
        hasil = a + b + c;
        document.getElementById("output_hasil").innerText = "Hasil Keliling: " + hasil;
    } else if (rumusAktif === 'sisi') {
        hasil = Math.sqrt((a * a) + (b * b)); // Rumus Pythagoras cari Sisi Miring C
        document.getElementById("output_hasil").innerText = "Sisi Miring C = " + hasil.toFixed(2);
    } else if (rumusAktif === 'sin') {
        hasil = Math.sin(a * Math.PI / 180);
        document.getElementById("output_hasil").innerText = "Hasil Sin(" + a + "°) = " + hasil.toFixed(4);
    } else if (rumusAktif === 'cos') {
        hasil = Math.cos(a * Math.PI / 180);
        document.getElementById("output_hasil").innerText = "Hasil Cos(" + a + "°) = " + hasil.toFixed(4);
    } else if (rumusAktif === 'tan') {
        hasil = Math.tan(a * Math.PI / 180);
        document.getElementById("output_hasil").innerText = "Hasil Tan(" + a + "°) = " + hasil.toFixed(4);
    } else {
        document.getElementById("output_hasil").innerText = "Hasil: -";
    }
}
</script>
</body>
</html>
